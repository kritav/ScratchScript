project
  variable score = 0
  variable gravity = -2
  variable velocity = 0
  variable gameRunning = 0
  backdrops "Blue Sky"

  sprite Bird
    costumes "cat-a"
    position -100, 0
    size 50

    variable velocity = 0

    script
      when flag clicked
        set score to 0
        set velocity to 0
        set gameRunning to 1
        go to x y -100 0
        show
        forever
          change velocity by gravity
          change y by velocity
          if y position < -170
            set gameRunning to 0
            say "Game Over!" 2
            stop all
          if y position > 170
            set y to 170
            set velocity to 0

    script
      when key space pressed
        if gameRunning = 1
          set velocity to 10

  sprite Pipe
    costumes "ball-a"
    position 240, 0
    size 100

    script
      when flag clicked
        forever
          go to x y 240 (pick random -100 100)
          repeat 120
            change x by -4
            if touching "Bird"
              set gameRunning to 0
              broadcast "game over"
              stop all
          if x position < -240
            change score by 1
